<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Palette: Forest (Kontrast-Stufe 3 — dunkler + wärmer).
    Background ist deutlich getönt — kein fast-weißes Grundraster mehr.
    Nur Farb-Brushes. Geometrie kommt aus sharp.xaml / soft.xaml.
  -->

  <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="Theme.PaletteMarker">Forest</sys:String>

  <!-- Accent -->
  <SolidColorBrush x:Key="Theme.Accent"        Color="#2F5233"/>
  <SolidColorBrush x:Key="Theme.AccentLight"   Color="#B4C9AE"/>
  <SolidColorBrush x:Key="Theme.AccentHover"   Color="#213820"/>

  <!-- Border -->
  <SolidColorBrush x:Key="Theme.Border"        Color="#5F8155"/>
  <SolidColorBrush x:Key="Theme.BorderStrong"  Color="#426139"/>

  <!-- Flächen -->
  <SolidColorBrush x:Key="Theme.Background"    Color="#DBE6D4"/>
  <SolidColorBrush x:Key="Theme.SoftBg"        Color="#BED1B6"/>
  <SolidColorBrush x:Key="Theme.HeaderBg"      Color="#9FB692"/>
  <SolidColorBrush x:Key="Theme.GridLine"      Color="#93B284"/>

  <!-- Text -->
  <SolidColorBrush x:Key="Theme.TextPrimary"   Color="#0C1B0D"/>
  <SolidColorBrush x:Key="Theme.TextSecondary" Color="#1E2F1E"/>

  <!-- Status (palette-unabhängig, semantisch) -->
  <SolidColorBrush x:Key="Theme.StatusOk"      Color="#107C10"/>
  <SolidColorBrush x:Key="Theme.StatusWarn"    Color="#CA5010"/>
  <SolidColorBrush x:Key="Theme.StatusErr"     Color="#C50F1F"/>
</ResourceDictionary>