<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Palette: Gray (Kontrast-Stufe 3 — dunkler + wärmer).
    Background ist deutlich getönt — kein fast-weißes Grundraster mehr.
    Nur Farb-Brushes. Geometrie kommt aus sharp.xaml / soft.xaml.
  -->

  <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="Theme.PaletteMarker">Gray</sys:String>

  <!-- Accent -->
  <SolidColorBrush x:Key="Theme.Accent"        Color="#0078D4"/>
  <SolidColorBrush x:Key="Theme.AccentLight"   Color="#BAD6EF"/>
  <SolidColorBrush x:Key="Theme.AccentHover"   Color="#106EBE"/>

  <!-- Border -->
  <SolidColorBrush x:Key="Theme.Border"        Color="#9A948A"/>
  <SolidColorBrush x:Key="Theme.BorderStrong"  Color="#767067"/>

  <!-- Flächen -->
  <SolidColorBrush x:Key="Theme.Background"    Color="#F2EFE9"/>
  <SolidColorBrush x:Key="Theme.SoftBg"        Color="#E0DCD2"/>
  <SolidColorBrush x:Key="Theme.HeaderBg"      Color="#CEC9BD"/>
  <SolidColorBrush x:Key="Theme.GridLine"      Color="#C0BAAE"/>

  <!-- Text -->
  <SolidColorBrush x:Key="Theme.TextPrimary"   Color="#141414"/>
  <SolidColorBrush x:Key="Theme.TextSecondary" Color="#3C3C3C"/>

  <!-- Status (palette-unabhängig, semantisch) -->
  <SolidColorBrush x:Key="Theme.StatusOk"      Color="#107C10"/>
  <SolidColorBrush x:Key="Theme.StatusWarn"    Color="#CA5010"/>
  <SolidColorBrush x:Key="Theme.StatusErr"     Color="#C50F1F"/>
</ResourceDictionary>