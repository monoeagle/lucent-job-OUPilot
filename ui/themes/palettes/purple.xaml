<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Palette: Purple (Kontrast-Stufe 3 — dunkler + wärmer).
    Background ist deutlich getönt — kein fast-weißes Grundraster mehr.
    Nur Farb-Brushes. Geometrie kommt aus sharp.xaml / soft.xaml.
  -->

  <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="Theme.PaletteMarker">Purple</sys:String>

  <!-- Accent -->
  <SolidColorBrush x:Key="Theme.Accent"        Color="#6B46C1"/>
  <SolidColorBrush x:Key="Theme.AccentLight"   Color="#C6B2E2"/>
  <SolidColorBrush x:Key="Theme.AccentHover"   Color="#533597"/>

  <!-- Border -->
  <SolidColorBrush x:Key="Theme.Border"        Color="#8A78B8"/>
  <SolidColorBrush x:Key="Theme.BorderStrong"  Color="#685696"/>

  <!-- Flächen -->
  <SolidColorBrush x:Key="Theme.Background"    Color="#E7DFF3"/>
  <SolidColorBrush x:Key="Theme.SoftBg"        Color="#D2C6E8"/>
  <SolidColorBrush x:Key="Theme.HeaderBg"      Color="#B7A6D4"/>
  <SolidColorBrush x:Key="Theme.GridLine"      Color="#B09ED2"/>

  <!-- Text -->
  <SolidColorBrush x:Key="Theme.TextPrimary"   Color="#1B1128"/>
  <SolidColorBrush x:Key="Theme.TextSecondary" Color="#362A48"/>

  <!-- Status (palette-unabhängig, semantisch) -->
  <SolidColorBrush x:Key="Theme.StatusOk"      Color="#107C10"/>
  <SolidColorBrush x:Key="Theme.StatusWarn"    Color="#CA5010"/>
  <SolidColorBrush x:Key="Theme.StatusErr"     Color="#C50F1F"/>
</ResourceDictionary>