<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Palette: Coral (Kontrast-Stufe 3 — dunkler + wärmer).
    Background ist deutlich getönt — kein fast-weißes Grundraster mehr.
    Nur Farb-Brushes. Geometrie kommt aus sharp.xaml / soft.xaml.
  -->

  <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="Theme.PaletteMarker">Coral</sys:String>

  <!-- Accent -->
  <SolidColorBrush x:Key="Theme.Accent"        Color="#D84F4F"/>
  <SolidColorBrush x:Key="Theme.AccentLight"   Color="#EEBDBD"/>
  <SolidColorBrush x:Key="Theme.AccentHover"   Color="#A83636"/>

  <!-- Border -->
  <SolidColorBrush x:Key="Theme.Border"        Color="#A86F6F"/>
  <SolidColorBrush x:Key="Theme.BorderStrong"  Color="#875151"/>

  <!-- Flächen -->
  <SolidColorBrush x:Key="Theme.Background"    Color="#F2D7D7"/>
  <SolidColorBrush x:Key="Theme.SoftBg"        Color="#E4BCBC"/>
  <SolidColorBrush x:Key="Theme.HeaderBg"      Color="#D29D9D"/>
  <SolidColorBrush x:Key="Theme.GridLine"      Color="#C68F8F"/>

  <!-- Text -->
  <SolidColorBrush x:Key="Theme.TextPrimary"   Color="#2A0E0E"/>
  <SolidColorBrush x:Key="Theme.TextSecondary" Color="#442222"/>

  <!-- Status (palette-unabhängig, semantisch) -->
  <SolidColorBrush x:Key="Theme.StatusOk"      Color="#107C10"/>
  <SolidColorBrush x:Key="Theme.StatusWarn"    Color="#CA5010"/>
  <SolidColorBrush x:Key="Theme.StatusErr"     Color="#C50F1F"/>
</ResourceDictionary>