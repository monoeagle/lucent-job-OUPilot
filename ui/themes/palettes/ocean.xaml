<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Palette: Ocean (Kontrast-Stufe 3 — dunkler + wärmer).
    Background ist deutlich getönt — kein fast-weißes Grundraster mehr.
    Nur Farb-Brushes. Geometrie kommt aus sharp.xaml / soft.xaml.
  -->

  <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="Theme.PaletteMarker">Ocean</sys:String>

  <!-- Accent -->
  <SolidColorBrush x:Key="Theme.Accent"        Color="#0F4C81"/>
  <SolidColorBrush x:Key="Theme.AccentLight"   Color="#ADC3D8"/>
  <SolidColorBrush x:Key="Theme.AccentHover"   Color="#093861"/>

  <!-- Border -->
  <SolidColorBrush x:Key="Theme.Border"        Color="#5B7E9E"/>
  <SolidColorBrush x:Key="Theme.BorderStrong"  Color="#3F617F"/>

  <!-- Flächen -->
  <SolidColorBrush x:Key="Theme.Background"    Color="#DAE4EE"/>
  <SolidColorBrush x:Key="Theme.SoftBg"        Color="#BECDDD"/>
  <SolidColorBrush x:Key="Theme.HeaderBg"      Color="#97B3CB"/>
  <SolidColorBrush x:Key="Theme.GridLine"      Color="#8EA9C2"/>

  <!-- Text -->
  <SolidColorBrush x:Key="Theme.TextPrimary"   Color="#061B2B"/>
  <SolidColorBrush x:Key="Theme.TextSecondary" Color="#223649"/>

  <!-- Status (palette-unabhängig, semantisch) -->
  <SolidColorBrush x:Key="Theme.StatusOk"      Color="#107C10"/>
  <SolidColorBrush x:Key="Theme.StatusWarn"    Color="#CA5010"/>
  <SolidColorBrush x:Key="Theme.StatusErr"     Color="#C50F1F"/>
</ResourceDictionary>