<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Palette: Rose (Kontrast-Stufe 3 — dunkler + wärmer).
    Background ist deutlich getönt — kein fast-weißes Grundraster mehr.
    Nur Farb-Brushes. Geometrie kommt aus sharp.xaml / soft.xaml.
  -->

  <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="Theme.PaletteMarker">Rose</sys:String>

  <!-- Accent -->
  <SolidColorBrush x:Key="Theme.Accent"        Color="#B83280"/>
  <SolidColorBrush x:Key="Theme.AccentLight"   Color="#E4B3CC"/>
  <SolidColorBrush x:Key="Theme.AccentHover"   Color="#8E2563"/>

  <!-- Border -->
  <SolidColorBrush x:Key="Theme.Border"        Color="#A37889"/>
  <SolidColorBrush x:Key="Theme.BorderStrong"  Color="#82566A"/>

  <!-- Flächen -->
  <SolidColorBrush x:Key="Theme.Background"    Color="#F0DFE9"/>
  <SolidColorBrush x:Key="Theme.SoftBg"        Color="#DEC9D5"/>
  <SolidColorBrush x:Key="Theme.HeaderBg"      Color="#CAACBE"/>
  <SolidColorBrush x:Key="Theme.GridLine"      Color="#BFA2B4"/>

  <!-- Text -->
  <SolidColorBrush x:Key="Theme.TextPrimary"   Color="#280F20"/>
  <SolidColorBrush x:Key="Theme.TextSecondary" Color="#422838"/>

  <!-- Status (palette-unabhängig, semantisch) -->
  <SolidColorBrush x:Key="Theme.StatusOk"      Color="#107C10"/>
  <SolidColorBrush x:Key="Theme.StatusWarn"    Color="#CA5010"/>
  <SolidColorBrush x:Key="Theme.StatusErr"     Color="#C50F1F"/>
</ResourceDictionary>